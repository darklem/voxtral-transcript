<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <cat.canigo.voxtral.FloatingEmojiView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFF0F8FF"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CCFFFFFF"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#CC9C27B0"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🦄 Voxtral Voice 🎈"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Prêt à enregistrer"
                android:textSize="13sp"
                android:textColor="#EDE7F6"
                android:paddingTop="2dp"/>
        </LinearLayout>

        <!-- Stats bar -->
        <TextView
            android:id="@+id/tvStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📊 0 transcription  •  0s  •  $0.0000"
            android:textSize="11sp"
            android:textColor="#7B1FA2"
            android:background="#FFECE7F6"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"/>

        <!-- Record button zone -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="20dp"
            android:background="#99FFFFFF">

            <Button
                android:id="@+id/btnRecord"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:text="🎙️"
                android:textSize="44sp"
                android:backgroundTint="#9C27B0"
                android:textColor="#FFFFFF"/>

            <TextView
                android:id="@+id/tvRecordLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Appuyer pour enregistrer"
                android:textSize="13sp"
                android:textColor="#7B1FA2"
                android:paddingTop="10dp"/>

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:paddingTop="6dp"/>
        </LinearLayout>

        <!-- Transcriptions header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="  💕 Transcriptions"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#7B1FA2"
            android:background="#99E1BEE7"
            android:padding="10dp"/>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="12dp">

            <LinearLayout
                android:id="@+id/transcriptionsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

        </ScrollView>

    </LinearLayout>
</FrameLayout>
